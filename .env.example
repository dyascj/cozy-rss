# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api

# Public URL for your Supabase project (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous key for client-side operations (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key for server-side operations (KEEP SECRET - never commit!)
# This key bypasses Row Level Security - handle with care
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
